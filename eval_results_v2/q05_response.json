              "sql": "WITH __flights AS (\n  SELECT\n    destination AS destination_airport,\n    flight_date,\n    flight_number,\n    status AS flight_status,\n    origin AS origin_airport,\n    aircraft_id,\n    flight_id,\n    load_factor,\n    passengers_booked\n  FROM PHANTOM_IROPS.STAGING.STG_FLIGHTS\n), __aircraft AS (\n  SELECT\n    aircraft_id\n  FROM PHANTOM_IROPS.STAGING.STG_AIRCRAFT\n)\nSELECT\n  f.flight_id,\n  f.flight_number,\n  f.flight_date,\n  f.origin_airport,\n  f.destination_airport,\n  f.flight_status,\n  f.aircraft_id,\n  a.aircraft_id AS matched_aircraft_id,\n  f.passengers_booked,\n  f.load_factor,\n  MIN(f.flight_date) OVER () AS min_flight_date,\n  MAX(f.flight_date) OVER () AS max_flight_date,\n  COUNT(f.flight_id) OVER () AS total_ghost_flights\nFROM __flights AS f\nLEFT OUTER JOIN __aircraft AS a\n  ON f.aircraft_id = a.aircraft_id\nWHERE\n  f.flight_date <= CURRENT_DATE\n  AND (\n    f.aircraft_id IS NULL OR a.aircraft_id IS NULL\n  )\nORDER BY\n  f.flight_date DESC NULLS LAST\n -- Generated by Cortex Analyst (request_id: 30d40e42-9584-4d92-b050-334853df723b)\n;",
