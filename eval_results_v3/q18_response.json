              "sql": "SELECT *\nFROM SEMANTIC_VIEW(\n    PHANTOM_IROPS.SEMANTIC_MODELS.IROPS_ANALYTICS\n    METRICS\n        disruption_count,\n        SUM(disruptions.impact_flights_count) AS total_impacted_flights,\n        SUM(disruptions.reported_cost_usd) AS total_reported_cost\n    DIMENSIONS\n        disruptions.disruption_type\n    WHERE disruptions.disruption_type = 'MECHANICAL'\n)\nORDER BY disruption_count DESC NULLS LAST\n -- Generated by Cortex Analyst (request_id: 546f41a8-700d-40b6-8906-3d187d680d2f)\n;",
